const gradeBands = [
  { min: 9.5, label: "Gem Mint-ish" },
  { min: 8.5, label: "Mint-ish" },
  { min: 7.0, label: "Near Mint" },
  { min: 5.5, label: "Excellent" },
  { min: 4.0, label: "Good" },
  { min: 0.0, label: "Played" },
];

type AnalysisResult = {
  previewUrl: string;
  width: number;
  height: number;
  metrics: {
    centering: number;
    corners: number;
    edges: number;
    surface: number;
    lighting: number;
    crop: number;
  };
  technical: {
    brightness: number;
    contrast: number;
    glareRatio: number;
  };
  grade: number;
  band: string;
  explanation: string[];
};

type CardMatch = {
  id: string;
  name: string;
  number: string;
