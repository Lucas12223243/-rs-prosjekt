                    <p className="mt-1 text-lg font-bold text-yellow-300">
                      {result.metrics.lighting}
                    </p>
                  </div>

                  <div className="rounded-2xl border border-white/10 bg-white/5 p-3 text-center">
                    <p className="text-xs uppercase tracking-[0.2em] text-slate-400">
                      Crop
                    </p>
                    <p className="mt-1 text-lg font-bold text-yellow-300">
                      {result.metrics.crop}
                    </p>
                  </div>

                  <div className="rounded-2xl border border-white/10 bg-white/5 p-3 text-center">
                    <p className="text-xs uppercase tracking-[0.2em] text-slate-400">
                      Glare
                    </p>
                    <p className="mt-1 text-lg font-bold text-yellow-300">
                      {result.technical.glareRatio}%
                    </p>
                  </div>
                </div>
              </div>

              <div className="space-y-5 rounded-[28px] border border-white/10 bg-white/[0.04] p-5">
                <div className="flex flex-wrap items-start justify-between gap-4">
                  <div>
                    <p className="text-sm uppercase tracking-[0.28em] text-slate-400">
                      Estimated Grade
                    </p>

                    <div className="mt-2 flex items-center gap-3">
                      <span
                        className={`bg-gradient-to-r ${gradeColor} bg-clip-text text-6xl font-black text-transparent`}
                      >
                        {result.grade}
                      </span>
                      <Badge className="rounded-full border-0 bg-white/10 px-3 py-1 text-white">
                        {result.band}
                      </Badge>
                    </div>

                    <p className="mt-4 text-sm text-slate-300">
                      Card:{" "}
                      <span className="font-semibold text-yellow-300">
                        {matchedCard?.name ?? (cardNameInput || "Unknown")}
                      </span>
                    </p>

                    <p className="mt-2 text-sm text-slate-300">
                      Number:{" "}
                      <span className="font-semibold text-yellow-300">
                        {matchedCard?.number ?? (cardNumberInput || "Unknown")}
                      </span>
                    </p>

                    <p className="mt-2 text-sm text-emerald-300">
                      Saved to collection portfolio automatically.
                    </p>
