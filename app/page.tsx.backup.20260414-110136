};

type SavedCard = {
  id: string;
  createdAt: string;
  uploadedImageUrl: string;
  grade: number;
  band: string;
  metrics: AnalysisResult["metrics"];
  cardName: string;
  enteredName: string;
  enteredNumber: string;
  matchedCardId?: string;
  setName?: string;
  setSeries?: string;
  setPrintedTotal?: number;
  setSymbolUrl?: string;
  rarity?: string;
  marketPrice?: number | null;
  lowPrice?: number | null;
  highPrice?: number | null;
  tcgplayerUrl?: string;
  source: "vision_plus_browser_estimate";
};

function clamp(value: number, min: number, max: number) {
  return Math.max(min, Math.min(max, value));
}

function getBandLabel(grade: number) {
  return gradeBands.find((band) => grade >= band.min)?.label ?? "Unknown";
}

function scoreToGrade(score: number) {
  const mapped = 3 + (score / 100) * 7;
  return Math.round(clamp(mapped, 1, 10) * 10) / 10;
}

function metricToPercentLabel(value: number) {
  return `${Math.round(value)}%`;
}

function getGradeColor(grade: number) {
  if (grade >= 9.5) return "from-emerald-400 to-teal-500";
  if (grade >= 8) return "from-sky-400 to-blue-500";
  if (grade >= 6) return "from-yellow-400 to-orange-500";
  return "from-rose-400 to-red-500";
}

function formatDate(dateIso: string) {
  return new Date(dateIso).toLocaleString();
}

function formatPrice(value?: number | null) {
  if (typeof value !== "number" || Number.isNaN(value)) return "N/A";
  return new Intl.NumberFormat("en-US", {
    style: "currency",
    currency: "USD",
    minimumFractionDigits: 2,
    maximumFractionDigits: 2,
  }).format(value);
}

async function fileToDataUrl(file: File): Promise<string> {
  return await new Promise((resolve, reject) => {
    const reader = new FileReader();
    reader.onload = () => resolve(String(reader.result || ""));
    reader.onerror = reject;
    reader.readAsDataURL(file);
  });
}

async function analyzeImage(file: File): Promise<AnalysisResult> {
  const objectUrl = URL.createObjectURL(file);

  const img = await new Promise<HTMLImageElement>((resolve, reject) => {
    const el = new window.Image();
    el.onload = () => resolve(el);
    el.onerror = reject;
    el.src = objectUrl;
  });

  const maxSize = 900;
  const ratio = Math.min(maxSize / img.width, maxSize / img.height, 1);
  const width = Math.max(1, Math.round(img.width * ratio));
  const height = Math.max(1, Math.round(img.height * ratio));

  const canvas = document.createElement("canvas");
  canvas.width = width;
  canvas.height = height;

  const ctx = canvas.getContext("2d", { willReadFrequently: true });
  if (!ctx) {
    URL.revokeObjectURL(objectUrl);
    throw new Error("Canvas context unavailable.");
  }

  ctx.drawImage(img, 0, 0, width, height);
  const { data } = ctx.getImageData(0, 0, width, height);

  let brightnessSum = 0;
  let brightnessSqSum = 0;
  let glarePixels = 0;
  let darkPixels = 0;
  let borderPenalty = 0;
  let minX = width;
  let minY = height;
  let maxX = 0;
  let maxY = 0;
  let foundCardLikeRegion = false;

  for (let y = 0; y < height; y++) {
    for (let x = 0; x < width; x++) {
      const i = (y * width + x) * 4;
      const r = data[i];
      const g = data[i + 1];
      const b = data[i + 2];

      const brightness = 0.299 * r + 0.587 * g + 0.114 * b;
      brightnessSum += brightness;
      brightnessSqSum += brightness * brightness;

      if (brightness > 245) glarePixels += 1;
      if (brightness < 28) darkPixels += 1;

      const sat = Math.max(r, g, b) - Math.min(r, g, b);
      const looksLikeCardBody = brightness > 40 && brightness < 245 && sat > 12;

      if (looksLikeCardBody) {
        foundCardLikeRegion = true;
        minX = Math.min(minX, x);
        minY = Math.min(minY, y);
        maxX = Math.max(maxX, x);
        maxY = Math.max(maxY, y);
      }

      const isBorder = x < 12 || y < 12 || x > width - 13 || y > height - 13;
      if (isBorder) {
        borderPenalty += Math.abs(brightness - 130) / 130;
      }
    }
  }

  const totalPixels = width * height;
  const avgBrightness = brightnessSum / totalPixels;
  const variance = brightnessSqSum / totalPixels - avgBrightness * avgBrightness;
  const stdDev = Math.sqrt(Math.max(variance, 0));
  const glareRatio = glarePixels / totalPixels;
  const darkRatio = darkPixels / totalPixels;

  const borderScore = clamp(
    100 - (borderPenalty / (width * 24 + height * 24)) * 100,
    0,
    100
  );

  let centeringScore = 62;
  let cropScore = 68;

  if (foundCardLikeRegion) {
    const left = minX;
    const right = width - maxX;
    const top = minY;
    const bottom = height - maxY;

    const horizontalCenterPenalty = Math.abs(left - right) / Math.max(width, 1);
    const verticalCenterPenalty = Math.abs(top - bottom) / Math.max(height, 1);

    centeringScore = clamp(
      100 - (horizontalCenterPenalty * 130 + verticalCenterPenalty * 130),
      30,
      98
    );

    const marginMin = Math.min(left, right, top, bottom);
    cropScore = clamp((marginMin / Math.min(width, height)) * 480, 22, 98);
  }

  const lightingScore = clamp(
    100 - glareRatio * 700 - darkRatio * 220 - Math.abs(avgBrightness - 142) * 0.46,
    18,
    99
  );

  const surfaceScore = clamp(45 + stdDev * 0.58 - glareRatio * 420, 20, 98);
  const cornersScore = clamp(cropScore * 0.58 + borderScore * 0.42, 20, 98);
  const edgesScore = clamp(borderScore * 0.7 + lightingScore * 0.3, 20, 98);

  const overallScore = clamp(
    centeringScore * 0.3 +
      cornersScore * 0.24 +
      edgesScore * 0.22 +
      surfaceScore * 0.24,
    1,
    100
  );

  const grade = scoreToGrade(overallScore);

  const explanation: string[] = [];
  if (glareRatio > 0.04) explanation.push("Strong glare detected.");
  if (cropScore < 50) explanation.push("The card may be cropped too tightly.");
  if (centeringScore < 70) explanation.push("The card looks off-center in the image.");
  if (lightingScore > 80) explanation.push("Lighting looks good enough for a rough estimate.");
  if (explanation.length === 0) {
    explanation.push("Photo quality looks usable for a rough estimate.");
  }

  const previewUrl = canvas.toDataURL("image/jpeg", 0.92);
  URL.revokeObjectURL(objectUrl);

  return {
    previewUrl,
    width,
    height,
    metrics: {
      centering: Math.round(centeringScore),
      corners: Math.round(cornersScore),
      edges: Math.round(edgesScore),
      surface: Math.round(surfaceScore),
      lighting: Math.round(lightingScore),
      crop: Math.round(cropScore),
    },
    technical: {
      brightness: Math.round(avgBrightness),
      contrast: Math.round(stdDev),
      glareRatio: +(glareRatio * 100).toFixed(1),
    },
    grade,
    band: getBandLabel(grade),
    explanation,
  };
}

function MetricBar({ label, value }: { label: string; value: number }) {
  return (
    <div className="space-y-2">
      <div className="flex items-center justify-between text-sm">
        <span className="text-slate-200">{label}</span>
        <span className="font-semibold text-yellow-300">
          {metricToPercentLabel(value)}
        </span>
      </div>
      <Progress value={value} className="h-2 bg-white/10" />
    </div>
  );
}

export default function PokemonCardGraderSite() {
  const [selectedFile, setSelectedFile] = useState<File | null>(null);
  const [selectedPreview, setSelectedPreview] = useState("");
  const [isAnalyzing, setIsAnalyzing] = useState(false);
  const [isFindingLikelyCard, setIsFindingLikelyCard] = useState(false);
  const [result, setResult] = useState<AnalysisResult | null>(null);
  const [visionGuess, setVisionGuess] = useState<VisionGuess | null>(null);
  const [candidateCards, setCandidateCards] = useState<CardMatch[]>([]);
  const [showModal, setShowModal] = useState(false);
  const [error, setError] = useState("");
  const [lookupError, setLookupError] = useState("");
  const [activeTab, setActiveTab] = useState<"scanner" | "collection">("scanner");
  const [savedCards, setSavedCards] = useState<SavedCard[]>([]);
  const [cardNameInput, setCardNameInput] = useState("");
  const [cardNumberInput, setCardNumberInput] = useState("");
  const [matchedCard, setMatchedCard] = useState<CardMatch | null>(null);
  const fileInputRef = useRef<HTMLInputElement>(null);

  useEffect(() => {
    const raw = window.localStorage.getItem(STORAGE_KEY);
    if (!raw) return;

    try {
      const parsed = JSON.parse(raw) as SavedCard[];
      setSavedCards(parsed);
    } catch {
      window.localStorage.removeItem(STORAGE_KEY);
    }
  }, []);

  useEffect(() => {
    window.localStorage.setItem(STORAGE_KEY, JSON.stringify(savedCards));
  }, [savedCards]);

  useEffect(() => {
    return () => {
      if (selectedPreview) URL.revokeObjectURL(selectedPreview);
    };
  }, [selectedPreview]);

  const gradeColor = useMemo(() => getGradeColor(result?.grade ?? 7), [result]);

  const handleFileChange = (event: React.ChangeEvent<HTMLInputElement>) => {
    const file = event.target.files?.[0];
    if (!file) return;

    setError("");
    setLookupError("");
    setResult(null);
    setMatchedCard(null);
    setVisionGuess(null);
    setCandidateCards([]);
    setShowModal(false);
    setCardNameInput("");
    setCardNumberInput("");

    if (selectedPreview) URL.revokeObjectURL(selectedPreview);

    setSelectedFile(file);
    setSelectedPreview(URL.createObjectURL(file));
  };

  const handleFindLikelyCard = async () => {
    if (!selectedFile) {
      setError("Upload a card photo first.");
      return;
    }

    try {
      setIsFindingLikelyCard(true);
      setError("");
      setLookupError("");
      setVisionGuess(null);
      setCandidateCards([]);
      setMatchedCard(null);

      const imageDataUrl = await fileToDataUrl(selectedFile);

      const response = await fetch("/api/identify-card", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
        },
        body: JSON.stringify({ imageDataUrl }),
      });

      const payload = await response.json();

      if (!response.ok) {
        throw new Error(payload?.error || "Card identification failed.");
      }

      const guess = payload?.guess as VisionGuess | null;
      const candidates = Array.isArray(payload?.candidates)
        ? (payload.candidates as CardMatch[])
        : [];

      setVisionGuess(guess);
      setCandidateCards(candidates);

      if (guess?.card_name) setCardNameInput(guess.card_name);
      if (guess?.card_number) setCardNumberInput(guess.card_number);

      if (candidates[0]) {
        setMatchedCard(candidates[0]);
      } else if (!guess?.card_name) {
        setLookupError("Could not identify the card confidently from the photo.");
      } else {
        setLookupError("Got a rough guess, but no strong database match yet.");
      }
    } catch (err) {
      console.error(err);
      setLookupError(
        err instanceof Error ? err.message : "Could not identify the card from the image."
      );
    } finally {
      setIsFindingLikelyCard(false);
    }
  };

  const saveCardToCollection = (analysis: AnalysisResult, foundCard: CardMatch | null) => {
    const entry: SavedCard = {
      id: crypto.randomUUID(),
      createdAt: new Date().toISOString(),
      uploadedImageUrl: analysis.previewUrl,
      grade: analysis.grade,
      band: analysis.band,
      metrics: analysis.metrics,
      cardName: foundCard?.name ?? (cardNameInput.trim() || "Unknown card"),
      enteredName: cardNameInput.trim(),
      enteredNumber: cardNumberInput.trim(),
      matchedCardId: foundCard?.id,
      setName: foundCard?.setName,
      setSeries: foundCard?.setSeries,
      setPrintedTotal: foundCard?.setPrintedTotal,
      setSymbolUrl: foundCard?.setSymbolUrl,
      rarity: foundCard?.rarity,
      marketPrice: foundCard?.marketPrice ?? null,
      lowPrice: foundCard?.lowPrice ?? null,
      highPrice: foundCard?.highPrice ?? null,
      tcgplayerUrl: foundCard?.tcgplayerUrl,
      source: "vision_plus_browser_estimate",
    };

    setSavedCards((current) => [entry, ...current]);
  };

  const handleAnalyze = async () => {
    if (!selectedFile) {
      setError("Upload a card photo first.");
      return;
    }

    try {
      setIsAnalyzing(true);
      setError("");
      setLookupError("");

      const analysis = await analyzeImage(selectedFile);

      setResult(analysis);
      setShowModal(true);
      saveCardToCollection(analysis, matchedCard);
    } catch (err) {
      console.error(err);
      setError("Could not read that image. Try a clearer JPG or PNG.");
    } finally {
      setIsAnalyzing(false);
    }
  };

  const handleDeleteCard = (id: string) => {
    setSavedCards((current) => current.filter((card) => card.id !== id));
  };

  const handleClearCollection = () => {
    setSavedCards([]);
  };

  return (
    <div className="min-h-screen bg-[radial-gradient(circle_at_top,_#1e3a8a_0%,_#0f172a_45%,_#020617_100%)] text-white">
      <div className="absolute inset-0 opacity-20 [background-image:linear-gradient(to_right,rgba(255,255,255,0.08)_1px,transparent_1px),linear-gradient(to_bottom,rgba(255,255,255,0.08)_1px,transparent_1px)] [background-size:32px_32px]" />

      <main className="relative mx-auto max-w-7xl px-6 py-10">
        <div className="mb-6 flex flex-wrap items-center justify-between gap-4">
          <div>
            <p className="text-sm uppercase tracking-[0.3em] text-slate-400">
              PokéGrade Lab
            </p>
            <h1 className="mt-2 text-3xl font-black sm:text-4xl">
              Vision Scanner + Collection Portfolio
            </h1>
          </div>

          <div className="flex rounded-2xl border border-white/10 bg-white/5 p-1">
            <button
              onClick={() => setActiveTab("scanner")}
              className={`rounded-xl px-4 py-2 text-sm font-semibold transition ${
                activeTab === "scanner"
                  ? "bg-yellow-400 text-slate-950"
                  : "text-slate-200 hover:bg-white/10"
              }`}
            >
              Scanner
            </button>

            <button
              onClick={() => setActiveTab("collection")}
              className={`rounded-xl px-4 py-2 text-sm font-semibold transition ${
                activeTab === "collection"
                  ? "bg-yellow-400 text-slate-950"
                  : "text-slate-200 hover:bg-white/10"
              }`}
            >
              My Collection
            </button>
          </div>
        </div>

        {activeTab === "scanner" ? (
          <motion.section
            initial={{ opacity: 0, y: 16 }}
            animate={{ opacity: 1, y: 0 }}
            className="grid gap-6 lg:grid-cols-[1.15fr_0.85fr]"
          >
            <Card className="overflow-hidden border-white/10 bg-white/10 shadow-2xl backdrop-blur-xl">
              <CardContent className="p-0">
                <div className="relative overflow-hidden rounded-2xl border-b border-white/10 bg-gradient-to-r from-yellow-300 via-yellow-400 to-red-500 p-8 text-slate-900">
                  <div className="absolute -right-10 -top-10 h-40 w-40 rounded-full bg-white/30 blur-3xl" />
                  <div className="absolute -bottom-16 left-24 h-40 w-40 rounded-full bg-sky-300/40 blur-3xl" />

                  <Badge className="mb-4 rounded-full border-0 bg-slate-950/85 px-3 py-1 text-yellow-300">
                    Vision-powered Card Finder
                  </Badge>

                  <div className="max-w-2xl space-y-4">
                    <h2 className="text-4xl font-black tracking-tight sm:text-5xl">
                      PokéGrade Lab
                    </h2>
                    <p className="max-w-xl text-base font-medium text-slate-800 sm:text-lg">
                      Upload a card photo, let vision identify likely matches, choose the
                      right card, then estimate grade and save it to your collection.
                    </p>

                    <div className="flex flex-wrap gap-3 text-sm font-semibold text-slate-900">
                      <div className="rounded-full bg-white/70 px-4 py-2">
                        Vision card recognition
                      </div>
                      <div className="rounded-full bg-white/70 px-4 py-2">
                        Top 5 likely matches
                      </div>
                      <div className="rounded-full bg-white/70 px-4 py-2">
                        Auto-save portfolio
                      </div>
                    </div>
                  </div>
                </div>

                <div className="grid gap-6 p-6 md:grid-cols-[1fr_0.95fr]">
                  <div className="space-y-4">
                    <div className="rounded-3xl border border-dashed border-yellow-300/50 bg-slate-950/40 p-5">
                      <div className="mb-4 flex items-center gap-3">
                        <div className="rounded-2xl bg-yellow-400/15 p-3 text-yellow-300">
                          <Upload className="h-5 w-5" />
                        </div>
                        <div>
                          <h2 className="text-lg font-bold">Upload and identify a card</h2>
                          <p className="text-sm text-slate-300">
                            Best results: one full card, straight angle, low glare.
                          </p>
                        </div>
                      </div>

                      <Input
                        ref={fileInputRef}
                        type="file"
                        accept="image/png,image/jpeg,image/webp"
                        onChange={handleFileChange}
                        className="border-white/10 bg-white/5 file:mr-4 file:rounded-full file:border-0 file:bg-yellow-400 file:px-4 file:py-2 file:font-semibold file:text-slate-950 hover:file:bg-yellow-300"
                      />

                      <div className="mt-4 grid gap-3 sm:grid-cols-2">
                        <div className="space-y-2">
                          <label className="text-sm font-semibold text-slate-200">
                            Card name
                          </label>
                          <div className="relative">
                            <Search className="pointer-events-none absolute left-3 top-1/2 h-4 w-4 -translate-y-1/2 text-slate-400" />
                            <Input
                              value={cardNameInput}
                              onChange={(e) => setCardNameInput(e.target.value)}
                              placeholder="Auto-filled from best match"
                              className="border-white/10 bg-white/5 pl-10"
                            />
                          </div>
                        </div>

                        <div className="space-y-2">
                          <label className="text-sm font-semibold text-slate-200">
                            Card number
                          </label>
                          <div className="relative">
                            <Hash className="pointer-events-none absolute left-3 top-1/2 h-4 w-4 -translate-y-1/2 text-slate-400" />
                            <Input
                              value={cardNumberInput}
                              onChange={(e) => setCardNumberInput(e.target.value)}
                              placeholder="Auto-filled from best match"
                              className="border-white/10 bg-white/5 pl-10"
                            />
                          </div>
                        </div>
                      </div>

                      <div className="mt-4 flex flex-wrap gap-3">
                        <Button
                          variant="outline"
                          onClick={handleFindLikelyCard}
                          disabled={isFindingLikelyCard || !selectedFile}
                          className="rounded-2xl border-white/15 bg-white/5 hover:bg-white/10"
                        >
                          <Wand2 className="mr-2 h-4 w-4" />
                          {isFindingLikelyCard ? "Finding likely card..." : "Find Likely Card"}
                        </Button>

                        <Button
                          onClick={handleAnalyze}
                          disabled={isAnalyzing || !selectedFile}
                          className="rounded-2xl bg-gradient-to-r from-yellow-400 to-red-500 px-5 text-slate-950 hover:opacity-95"
                        >
                          {isAnalyzing ? (
                            <>
                              <Sparkles className="mr-2 h-4 w-4 animate-pulse" />
                              Estimating grade...
                            </>
                          ) : (
                            <>
                              <ScanSearch className="mr-2 h-4 w-4" />
                              Estimate Grade + Save
                            </>
                          )}
                        </Button>

                        <Button
                          variant="outline"
                          onClick={() => fileInputRef.current?.click()}
                          className="rounded-2xl border-white/15 bg-white/5 hover:bg-white/10"
                        >
                          <Camera className="mr-2 h-4 w-4" />
                          Choose Another Photo
                        </Button>
                      </div>

                      {error ? <p className="mt-3 text-sm text-rose-300">{error}</p> : null}
                      {lookupError ? (
                        <p className="mt-2 text-sm text-yellow-200">{lookupError}</p>
                      ) : null}
                    </div>

                    {visionGuess ? (
                      <Card className="border-white/10 bg-slate-950/60 shadow-xl">
                        <CardHeader>
                          <CardTitle className="flex items-center gap-2 text-xl">
                            <Brain className="h-5 w-5 text-yellow-300" />
                            Vision guess
                          </CardTitle>
                        </CardHeader>
                        <CardContent className="space-y-3 text-sm">
                          <div className="grid gap-3 sm:grid-cols-2">
                            <div className="rounded-2xl border border-white/10 bg-white/5 p-4">
                              <p className="text-slate-400">Name</p>
                              <p className="font-bold text-white">
                                {visionGuess.card_name || "Unknown"}
                              </p>
                            </div>

                            <div className="rounded-2xl border border-white/10 bg-white/5 p-4">
                              <p className="text-slate-400">Collector number</p>
                              <p className="font-bold text-white">
                                {visionGuess.card_number || "Unknown"}
                              </p>
                            </div>
                          </div>

                          <div className="rounded-2xl border border-white/10 bg-white/5 p-4">
                            <p className="text-slate-400">Set guess</p>
                            <p className="font-bold text-white">
                              {visionGuess.set_name || "Unknown"}
                            </p>
                          </div>

                          <div className="rounded-2xl border border-white/10 bg-white/5 p-4">
                            <p className="text-slate-400">Confidence</p>
                            <p className="font-bold text-yellow-300">
                              {Math.round((visionGuess.confidence || 0) * 100)}%
                            </p>
                            <p className="mt-2 text-slate-300">{visionGuess.notes}</p>
                          </div>
                        </CardContent>
                      </Card>
                    ) : null}

                    {candidateCards.length > 0 ? (
                      <Card className="border-white/10 bg-slate-950/60 shadow-xl">
                        <CardHeader>
                          <CardTitle className="text-xl">Likely matches</CardTitle>
                        </CardHeader>
                        <CardContent className="space-y-3">
