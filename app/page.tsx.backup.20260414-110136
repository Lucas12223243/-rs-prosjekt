                <div className="grid gap-4 sm:grid-cols-2">
                  <MetricBar label="Centering" value={result.metrics.centering} />
                  <MetricBar label="Corners" value={result.metrics.corners} />
                  <MetricBar label="Edges" value={result.metrics.edges} />
                  <MetricBar label="Surface" value={result.metrics.surface} />
                </div>

                <div className="rounded-3xl border border-white/10 bg-slate-950/60 p-4">
                  <p className="mb-3 text-sm font-semibold text-slate-200">
                    What the estimator noticed
                  </p>
                  <ul className="space-y-2 text-sm text-slate-300">
                    {result.explanation.map((item) => (
                      <li key={item} className="rounded-2xl bg-white/5 px-3 py-2">
                        {item}
                      </li>
                    ))}
                  </ul>
                </div>
              </div>
            </motion.div>
          </motion.div>
        ) : null}
      </AnimatePresence>
    </div>
  );
