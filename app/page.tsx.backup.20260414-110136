                <X className="h-5 w-5" />
              </button>

              <div className="rounded-[28px] border border-white/10 bg-black/30 p-4">
                <div className={`mb-4 rounded-[24px] bg-gradient-to-br ${gradeColor} p-[2px]`}>
                  <div className="rounded-[22px] bg-slate-950/95 p-4">
                    <img
